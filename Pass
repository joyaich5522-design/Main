-- 5. Clipboard Activation Logic
ActionButton.Activated:Connect(function()
    setclipboard("https://sub2unlock.me/6LIOt0P")
    
    -- Compact visual feedback inside the grey theme
    ActionButton.Text = "Copied URL!"
    ActionButton.BackgroundColor3 = Color3.fromRGB(90, 90, 95) -- Mid-tone flash
    
