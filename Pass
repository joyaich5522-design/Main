-- 5. Force-Executed Safe Clipboard Logic
ActionButton.MouseButton1Click:Connect(function()
    -- Force the text to change instantly so you know the tap registered
    ActionButton.Text = "Testing Copy..."
    ActionButton.BackgroundColor3 = Color3.fromRGB(90, 90, 95)

    -- Try copying using a pcall block so the executor doesn't crash the script
    local success, err = pcall(function()
        if setclipboard then
            setclipboard("https://sub2unlock.me/6LIOt0P")
        elseif toclipboard then
            toclipboard("https://sub2unlock.me/6LIOt0P")
        elseif set_clipboard then
            set_clipboard("https://sub2unlock.me/6LIOt0P")
        else
            -- If the executor has a completely custom naming convention, force a default call
            setclipboard("https://sub2unlock.me/6LIOt0P")
        end
    end)

    -- Show results based on whether the executor accepted the command
    if success then
        ActionButton.Text = "Copied URL!"
    else
        ActionButton.Text = "Copy Error"
        warn("Clipboard crash bypassed: " .. tostring(err))
    end
    
    -- Delay reset using standard spawn to prevent UI freezing
    task.delay(2, function()
        ActionButton.Text = "Click me for Script"
        ActionButton.BackgroundColor3 = Color3.fromRGB(65, 65, 68)
    end)
end)
